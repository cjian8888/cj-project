# ============================================================
# Antigravity AI Ignore File
# ============================================================
# 排除大型目录和无关文件，减少 Context Window 占用

# ============================================================
# 依赖和虚拟环境 (必须排除)
# ============================================================
node_modules/
.venv/
venv/
ENV/
env/

# ============================================================
# Git 和 IDE (必须排除)
# ============================================================
.git/
.vscode/
.idea/
.cline/

# ============================================================  
# 缓存和编译文件 (必须排除)
# ============================================================
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ipynb_checkpoints/

# ============================================================
# 大型数据和输出目录 (建议排除)
# ============================================================
data/
output/
output_*/
archives/
backup_*/

# ============================================================
# 日志和临时文件
# ============================================================
*.log
*.log.*
*.tmp
*.temp
*.db
*.sqlite
*.sqlite3

# ============================================================
# 包管理器锁文件 (内容冗长无需分析)
# ============================================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================================
# 系统文件
# ============================================================
.DS_Store
Thumbs.db
