                        else ("赎回" if direction == "in" else "未知"),
                        "amount": amount,
                        "date": tx.get("date", ""),
                        "counterparty": counterparty,
                    }
                )

                if "购买" in summary or direction == "out":
                    total_purchase += amount
                elif "赎回" in summary or "收益" in summary or direction == "in":
