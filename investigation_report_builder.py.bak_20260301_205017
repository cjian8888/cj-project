    def _build_household_analysis_section(
        self, config: PrimaryTargetsConfig
    ) -> HouseholdAnalysisSection:
        """
        【v3.1】构建家庭分析章节（对齐用户模板）

        遍历所有家庭单元，为每个家庭构建：
        - family_roster: 成员清单（含关系证据）
        - family_level_analysis: 家庭层面分析
        """
        family_units_config = config.get_family_units()
        family_units = []
        total_persons_with_data = 0

        for unit_config in family_units_config:
            family_unit = self._build_single_family_unit(unit_config)
            family_units.append(family_unit)
            # 统计有数据的人员
            for member in family_unit.family_roster.members:
                if member.has_data:
                    total_persons_with_data += 1

        return HouseholdAnalysisSection(
            family_units=family_units,
            total_families=len(family_units),
            total_persons_with_data=total_persons_with_data,
        )

    def _build_single_family_unit(self, unit_config: AnalysisUnit) -> FamilyUnit:
        """构建单个家庭单元"""
        anchor = unit_config.anchor
        # unit_config.members 已经是字符串列表 List[str]
        members = unit_config.members

        # 1. 构建成员清单
        family_roster = self._build_family_roster(anchor, members)

        # 2. 构建家庭层面分析
        family_level_analysis = self._build_family_level_analysis(members)

        return FamilyUnit(
            unit_label=f"{anchor}家庭",
            anchor=anchor,
            family_roster=family_roster,
            family_level_analysis=family_level_analysis,
        )

    def _build_family_roster(self, anchor: str, members: List[str]) -> FamilyRoster:
        """构建家庭成员清单（含关系证据）"""
        # 从 family_units_v2 获取户籍信息
        family_units_v2 = self.derived_data.get("family_units_v2", [])

        # 查找匹配的家庭单元
        matched_unit = None
        for fu in family_units_v2:
            if fu.get("anchor") == anchor or anchor in fu.get("members", []):
                matched_unit = fu
                break

        householder = (
            matched_unit.get("householder", anchor) if matched_unit else anchor
        )
        address = matched_unit.get("address", "") if matched_unit else ""
        member_details_raw = (
            matched_unit.get("member_details", []) if matched_unit else []
        )
        extended_relatives = (
            matched_unit.get("extended_relatives", []) if matched_unit else []
        )

        # 构建成员列表（含关系证据）
        roster_members = []
        for name in members:
            # 从户籍数据中查找关系
            relation = "家庭成员"
            evidence_type = "推测"

            for md in member_details_raw:
                if md.get("name") == name:
                    relation = md.get("relation", "家庭成员")
                    evidence_type = "户籍确认"  # 来自户籍数据
                    break

            roster_members.append(
                FamilyRosterMember(
                    name=name,
                    relation=relation,
                    has_data=name in self.profiles,
                    id_number="",  # 隐私考虑，不直接暴露
                    relation_evidence=RelationEvidence(
                        evidence_type=evidence_type,
                        source="户籍登记信息"
                        if evidence_type == "户籍确认"
                        else "数据推断",
                        confidence=1.0 if evidence_type == "户籍确认" else 0.7,
                    ),
                )
            )

        return FamilyRoster(
            householder=householder,
            address=address,
            members=roster_members,
            extended_relatives=extended_relatives,
        )

    def _build_family_level_analysis(self, members: List[str]) -> FamilyLevelAnalysis:
        """构建家庭层面分析"""
        # 从 family_summary 获取汇总数据
        family_summary = self.derived_data.get("family_summary", {})

        # 1. 收支资产匹配分析
        income_asset_mismatch = self._build_income_asset_mismatch(
            members, family_summary
        )

        # 2. 内部互转风险分析
        joint_risks = self._build_joint_risks(members, family_summary)

        return FamilyLevelAnalysis(
            income_asset_mismatch=income_asset_mismatch, joint_risks=joint_risks
        )

    def _build_income_asset_mismatch(
        self, members: List[str], family_summary: Dict
    ) -> IncomeAssetMismatch:
        """构建收支资产匹配分析"""
        total_income = (
            family_summary.get("total_income_expense", {}).get("total_income", 0) or 0
        )
        total_expense = (
            family_summary.get("total_income_expense", {}).get("total_expense", 0) or 0
        )
        total_assets = family_summary.get("total_assets", {}).get("total", 0) or 0

        # 计算缺口
        income_covers_expense = total_income >= total_expense
        income_covers_assets = total_income >= total_assets
        gap_amount = max(0, total_expense - total_income, total_assets - total_income)

        # 生成分析文本
        if income_covers_expense and income_covers_assets:
            analysis_text = (
                "家庭总收入能够覆盖总支出及资产购置，未发现明显收支不抵情况。"
            )
            risk_level = "low"
        elif income_covers_expense:
            analysis_text = f"家庭总收入能覆盖日常支出，但资产价值存在约{gap_amount / 10000:.1f}万元缺口，需核实资产来源。"
            risk_level = "medium"
        else:
            analysis_text = f"家庭总支出超过总收入约{(total_expense - total_income) / 10000:.1f}万元，需核实超额支出来源。"
            risk_level = "high"

        return IncomeAssetMismatch(
            total_family_income=total_income,
            total_family_expense=total_expense,
            total_assets_value=total_assets,
            income_covers_expense=income_covers_expense,
            income_covers_assets=income_covers_assets,
            gap_amount=gap_amount,
            analysis_text=analysis_text,
            risk_level=risk_level,
        )

    def _build_joint_risks(
        self, members: List[str], family_summary: Dict
    ) -> JointRisks:
        """构建家庭成员间联合风险"""
        member_transfers = family_summary.get("member_transfers", {})

        internal_transfer_total = 0.0
        transfer_details = []

        for member_name, transfers in member_transfers.items():
            to_family = transfers.get("to_family", 0) or 0
            from_family = transfers.get("from_family", 0) or 0
            internal_transfer_total += to_family + from_family

            if to_family > 0 or from_family > 0:
                transfer_details.append(
                    {
                        "member": member_name,
                        "to_family": to_family,
                        "from_family": from_family,
                        "net": transfers.get("net", 0),
                    }
                )

        # 判断是否异常（内部互转超过总收入的50%）
        total_income = family_summary.get("total_income_expense", {}).get(
            "total_income", 1
        )
        has_anomaly = (
            internal_transfer_total > total_income * 0.5 if total_income else False
        )

        anomaly_description = ""
        risk_level = "low"
        if has_anomaly:
            ratio = (
                (internal_transfer_total / total_income * 100)
                if total_income > 0
                else 0
            )
            anomaly_description = f"家庭成员间互转金额{internal_transfer_total / 10000:.1f}万元，占总收入的{ratio:.0f}%，存在资金分散或隐匿风险。"
            risk_level = "medium"

        return JointRisks(
            internal_transfer_total=internal_transfer_total,
            transfer_details=transfer_details,
            has_anomaly=has_anomaly,
            anomaly_description=anomaly_description,
            risk_level=risk_level,
        )

