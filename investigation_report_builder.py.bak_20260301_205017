    def _build_enhanced_company_section(
        self, company: str, core_persons: List[str] = None
    ) -> Dict:
        """
        构建增强版公司章节（5维度分析）

        分析维度：
        1. 经营规模与合理性
        2. 与核心人员资金往来
        3. 公司间资金往来
