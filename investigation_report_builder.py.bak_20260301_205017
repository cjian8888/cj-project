    def build_report_with_config(
        self,
        config: PrimaryTargetsConfig,
        case_background: str = None,
        data_scope: str = None,
    ) -> Dict:
        """
        【G-05】按归集配置生成报告（新接口）

        根据 primary_targets.json 中的分析单元配置组织报告章节：
        - 核心家庭单元（family）: 聚合成员数据，生成合并章节
        - 独立关联单元（independent）: 每个成员独立成章

        Args:
            config: 归集配置对象
            case_background: 案件背景
            data_scope: 数据范围

        Returns:
            完整报告字典，包含按分析单元组织的章节
        """
        logger.info(
            f"[初查报告] 开始按归集配置生成报告，{len(config.analysis_units)} 个分析单元"
        )

        # 【调试】检查 self.derived_data 的内容
        logger.info(
            f"[初查报告] self.derived_data keys: {list(self.derived_data.keys())}"
        )
        if "family_units_v2" in self.derived_data:
            logger.info(
                f"[初查报告] family_units_v2 length: {len(self.derived_data['family_units_v2'])}"
            )
            for unit in self.derived_data["family_units_v2"]:
                logger.info(
                    f"[初查报告]   - Unit: anchor={unit.get('anchor')}, members={unit.get('members')}"
                )
        if "all_family_summaries" in self.derived_data:
            logger.info(
                f"[初查报告] all_family_summaries keys: {list(self.derived_data['all_family_summaries'].keys())}"
            )

        # 1. 构建元信息
        meta = self._build_meta(config.doc_number, case_background, data_scope)

        # 2. 按分析单元组织章节
        unit_sections = []  # 分析单元章节
        all_member_details = []  # 保留兼容性的成员详情列表

        for unit in config.analysis_units:
            unit_section = self._build_analysis_unit_section(unit)
            unit_sections.append(unit_section)

            # 将成员详情添加到旧格式兼容列表
            for member in unit_section.get("member_details", []):
                all_member_details.append(member)

        # 3. 构建公司报告
        companies_to_include = config.include_companies or self._companies
        company_reports = [self._build_company_report(c) for c in companies_to_include]

        # 4. 构建 family 结构（取第一个有数据的家庭单元作为主家庭，兼容旧前端）
        primary_family_unit = None
        if config.get_family_units():
            # 优先选择第一个家庭单元
            for unit in config.get_family_units():
                # 只统计有流水数据的成员
                members_with_data = [m.name for m in unit.member_details if m.has_data]
                if members_with_data:  # 至少有一个有数据
                    primary_family_unit = unit
                    break

        if not primary_family_unit and config.analysis_units:
            # 回退：使用第一个有数据的分析单元
            for unit in config.analysis_units:
                members_with_data = [m.name for m in unit.member_details if m.has_data]
                if members_with_data:  # 至少有一个有数据
                    primary_family_unit = unit
                    break

        if primary_family_unit:
            family = self._build_family_section_from_unit(primary_family_unit)
        else:
            # 无家庭单元或无有数据的单元，使用默认的第一个人员
            first_person = (
                self.get_available_primary_persons()[0]
                if self.get_available_primary_persons()
                else ""
            )
            family = self._build_family_section(first_person)

        # 5. 生成综合研判
        # 将 unit_sections 中的 member_details 转换为 MemberDetails 对象
        member_details_objs = self._convert_to_member_details_objs(all_member_details)
        conclusion = self._build_conclusion(member_details_objs, company_reports)

        # 6. v3.1 新增：构建家庭分析章节（对齐用户模板）
        household_section = self._build_household_analysis_section(config)

        # 组装完整报告 - 新增 household_analysis_section 字段
        report_dict = {
            "meta": asdict(meta)
            if hasattr(meta, "__dataclass_fields__")
            else meta.to_dict()
            if hasattr(meta, "to_dict")
            else meta,
            "family": family.to_dict()
            if hasattr(family, "to_dict")
            else asdict(family),
            # v3.1 新增：家庭分析章节
            "household_analysis_section": asdict(household_section),
            # 按分析单元组织的章节
            "analysis_units": unit_sections,
            # 兼容旧格式
            "member_details": [
                self._member_details_to_dict(m) for m in member_details_objs
            ],
            "companies": [
                c.to_dict() if hasattr(c, "to_dict") else asdict(c)
                for c in company_reports
            ],
            "conclusion": asdict(conclusion)
            if hasattr(conclusion, "__dataclass_fields__")
            else conclusion.to_dict()
            if hasattr(conclusion, "to_dict")
            else conclusion,
        }

        logger.info(
            f"[初查报告] 按配置生成完成，{len(unit_sections)} 个分析单元，{len(company_reports)} 个公司"
        )

        return report_dict

    # ==================== v4.1 新增：统一报告数据构建 ====================

    def build_unified_report_data(
        self, config: PrimaryTargetsConfig = None
    ) -> UnifiedReportData:
        """
        【v4.1 统一数据构建】构建统一报告数据（txt和HTML共享）

        修改此数据结构 = 同时影响txt和HTML

        Args:
            config: PrimaryTargetsConfig - 归集配置对象，如果不提供则使用默认配置

        Returns:
            UnifiedReportData - 包含所有报告章节的完整数据
        """
        logger.info("[统一数据] 开始构建统一报告数据...")

        # 1. 加载或使用配置
        if config is None:
            service = PrimaryTargetsService(
                data_dir=os.path.join(self.output_dir, "data"),
                output_dir=self.output_dir,
            )
            config, _, _ = service.get_or_create_config()

        # 2. 构建元信息
        meta = self._build_meta(config.doc_number, config.case_notes, None)

        # 3. 【根据配置】重新计算家庭汇总
        if config.analysis_units:
            logger.info(f"[统一数据] 使用用户配置重新计算家庭汇总...")
            family_data = self._build_family_data_from_config(config)
        else:
            logger.info("[统一数据] 使用缓存数据...")
            family_data = self._build_family_data_from_cache()

        # 4. 构建每个成员的完整报告
        members = []
        for unit in config.analysis_units:
            if unit.unit_type == "family":
                # 家庭单元：聚合所有成员
                for member_name in unit.members:
                    member = self._build_member_report_unified(
                        member_name,
                        unit.anchor,  # 用于关系推断
                        unit.members,  # 用于家庭汇总
                    )
                    members.append(member)
            else:
                # 独立单元：单个成员
                member = self._build_member_report_unified(
                    unit.anchor, unit.anchor, [unit.anchor]
                )
                members.append(member)

        # 5. 构建公司报告
        companies = [
            self._build_company_report(c)
            for c in config.include_companies or self._companies
        ]

        # 6. 构建可疑交易分析
        suspicious = self._build_suspicion_analysis_unified()

        # 7. 构建综合研判
        # 将members中的MemberReport转换为MemberDetails（用于现有逻辑）
        member_details_objs = [
            MemberDetails(
                name=m.name,
                relation=m.relation,
                total_income=m.income_expense.total_income,
                total_expense=m.income_expense.total_expense,
                transaction_count=m.income_expense.transaction_count,
                assets=PersonAssets(
                    total_assets=m.assets.total_assets,
                    bank_accounts_count=m.assets.property_count
                    + m.assets.vehicle_count,  # 使用银行卡数量
                    total_balance=m.assets.bank_balance,
                ),
                analysis=PersonAnalysis(
                    income_gap=IncomeGapAnalysis(
                        total_income=m.income_expense.total_income,
                        salary_income=m.income_expense.total_income
                        * (
                            m.risk_analysis.income_expense_match.score / 100
                        ),  # 简化计算
                        ratio=m.risk_analysis.income_expense_match.score / 100,
                        verdict=m.risk_analysis.income_expense_match.verdict,
                    ),
                    large_cash=LargeCashAnalysis(
                        total_amount=0,  # 从profile获取
                        deposit_amount=0,
                        withdraw_amount=0,
                        count=0,
                    ),
                    large_transfer=LargeTransferAnalysis(
                        threshold=config.LARGE_TRANSACTION_THRESHOLD,
                        count=0,
                        total_amount=0,
                    ),
                ),
            )
            for m in members
        ]

        conclusion = self._build_conclusion(member_details_objs, companies)

        # 8. 组装统一数据
        unified_data = UnifiedReportData(
            meta=meta,
            family_overview=family_data.overview,
            family_yearly_salary=family_data.yearly_salary,
            family_financial_profile=family_data.financial_profile,
            members=members,
            companies=companies,
            suspicious_transactions=suspicious,
            conclusion=conclusion,
        )

        logger.info(
            f"[统一数据] 构建完成: {len(members)}个成员, {len(companies)}个公司"
        )

        return unified_data

    def _build_unified_person_analysis(self, name: str) -> Dict:
        """
        【六维一体】构建个人统一分析数据

        六大维度：
        1. 概览卡片 - 总流入、真实收入、工资占比、风险等级
        2. 关键发现 - 核心问题 + 影响量化
        3. 收入透视 - 原始流水 → 剔除项 → 真实收入
        4. 支出去向 - TOP5对手方
        5. 时序分析 - 年度异常点
        6. 关联分析 - 家庭成员资金往来

        Args:
            name: 人员姓名

        Returns:
            Dict: 包含六个维度的分析数据
        """
        profile = self.profiles.get(name, {})
        if not profile:
            return {}

        total_inflow = profile.get("totalIncome", 0)
        salary_ratio_raw = profile.get("salaryRatio", 0)
        salary = total_inflow * salary_ratio_raw
        salary_ratio = salary_ratio_raw * 100
        real_income = profile.get("summary", {}).get("real_income", total_inflow)

        # 风险等级判定
        if salary_ratio >= 60:
            risk_level = "low"
        elif salary_ratio >= 40:
            risk_level = "medium"
        elif salary_ratio >= 20:
            risk_level = "high"
        else:
            risk_level = "critical"

        # 一、概览卡片
        overview = {
            "name": name,
            "total_inflow": round(total_inflow / 10000, 2),
            "real_income": round(real_income / 10000, 2),
            "salary_ratio": round(salary_ratio, 1),
            "salary": round(salary / 10000, 2),
            "risk_level": risk_level,
        }

        # 二、关键发现
        key_findings = []
        ic = profile.get("income_classification", {})
        unknown_income = ic.get("unknown_income", 0)
        if unknown_income > 5000000:
            key_findings.append(
                {
                    "type": "risk",
                    "description": f"存在{unknown_income / 10000:.2f}万元来源不明收入，需重点核实",
                    "impact": f"真实收入中{unknown_income / 10000:.2f}万元无法解释来源",
                }
            )

        # 三、收入透视（按模板格式）
        offset_detail = profile.get("summary", {}).get("offset_detail", {})
        self_transfer = offset_detail.get("self_transfer", 0)
        wealth_principal = offset_detail.get("wealth_principal", 0)
        deposit_redemption = offset_detail.get("deposit_redemption", 0)

        # 计算真实收入
        total_removed = self_transfer + wealth_principal + deposit_redemption
        real_income_calc = max(0, total_inflow - total_removed)

        income_breakdown = {
            "raw_inflow": round(total_inflow / 10000, 2),
            "deductions": [
                {
                    "name": "自我转账",
                    "amount": round(self_transfer / 10000, 2),
                    "reason": "账户间资金划转",
                },
                {
                    "name": "理财赎回本金",
                    "amount": round(wealth_principal / 10000, 2),
                    "reason": "投资理财本金返还",
                },
                {
                    "name": "定存到期本金",
                    "amount": round(deposit_redemption / 10000, 2),
                    "reason": "定期存款到期",
                },
            ],
            "real_income": round(real_income_calc / 10000, 2),
            "status": "verified"
            if unknown_income < 100000
            else ("partial" if unknown_income < 1000000 else "pending"),
        }

        # 四、支出去向分析
        total_expense = profile.get("totalExpense", 0)
        large_txs = self.derived_data.get("large_transactions", [])
        person_expense = [
            t
            for t in large_txs
            if t.get("person") == name and t.get("direction") == "expense"
        ]

        from collections import defaultdict

        cp_data = defaultdict(lambda: {"amount": 0, "count": 0})
        for t in person_expense:
            cp = t.get("counterparty", "未知") or "未知"
            amt = t.get("amount", 0)
            cp_data[cp]["amount"] += amt
            cp_data[cp]["count"] += 1

        top_counterparties = [
            {
                "name": cp,
                "amount": round(info["amount"] / 10000, 2),
                "count": info["count"],
            }
            for cp, info in sorted(
                cp_data.items(), key=lambda x: x[1]["amount"], reverse=True
            )[:5]
        ]

        # 五、时序分析（按模板格式）
        # 【P1修复】yearly_salary类型检查，确保是字典类型
        yearly_salary = profile.get("yearly_salary", {})
        if not isinstance(yearly_salary, dict):
            yearly_salary = {}
        yearly_data = []
        if yearly_salary:
            for year, data in sorted(yearly_salary.items()):
                if isinstance(data, dict):
                    inflow_wan = data.get("total", 0) / 10000
                elif isinstance(data, (int, float)):
                    inflow_wan = data / 10000
                else:
                    # 跳过非预期的数据类型（如list）
                    continue
                # 估算流出（简化处理）
                outflow_wan = inflow_wan * 0.95  # 假设流出约为流入的95%
                is_anomaly = inflow_wan > 100 or (inflow_wan < 10 and inflow_wan > 0)
                yearly_data.append(
                    {
                        "year": str(year),
                        "inflow": round(inflow_wan, 2),
                        "outflow": round(outflow_wan, 2),
                        "anomaly": is_anomaly,
                        "anomaly_type": "收入异常" if is_anomaly else None,
                    }
                )
        else:
            # 估算年度数据
            if total_inflow > 0:
                estimated_yearly = total_inflow / 3 / 10000
                for year in range(2023, 2026):
                    yearly_data.append(
                        {
                            "year": str(year),
                            "inflow": round(estimated_yearly, 2),
                            "outflow": round(estimated_yearly * 0.95, 2),
                            "anomaly": False,
                            "anomaly_type": None,
                        }
                    )

        # 六、关联分析
        family_units = self.derived_data.get("family_units_v2", [])
        family_members = []
        for unit in family_units:
            if unit.get("anchor") == name or name in unit.get("members", []):
                for m in unit.get("members", []):
                    if m != name:
                        family_members.append(
                            {
                                "name": m,
                                "relation": "家庭成员",
                                "net_flow": 0,
                                "direction": "balanced",
                            }
                        )

        return {
            "overview": overview,
            "key_findings": key_findings,
            "income_breakdown": income_breakdown,
            "outflow_analysis": {
                "total_outflow": round(total_expense / 10000, 2),
                "top_counterparties": top_counterparties,
            },
            "temporal_analysis": {"yearly_data": yearly_data},
            "relationship_analysis": {"family_members": family_members},
        }

    # ==================== 六维一体数据整合修复方法 ====================

    def _build_unified_person_analysis_v2(
        self, name: str, existing_section: Dict
    ) -> Dict:
        """
        【六维一体】构建个人统一分析数据 - 数据整合修复版

        关键修复：使用 existing_section（build_v4_person_section 生成的详细数据）
        避免重新从 profile 简化计算导致的数据丢失

        Args:
            name: 人员姓名
            existing_section: build_v4_person_section 返回的完整数据结构

        Returns:
            Dict: 包含六个维度的分析数据
        """
        if not existing_section:
            return self._build_unified_person_analysis(name)  # 回退到旧方法

        asset_section = existing_section.get("asset_income_section", {})
        data_section = existing_section.get("data_analysis_section", {})

        # ===== 一、概览卡片 =====
        total_income = asset_section.get("total_income", 0)
        total_income_wan = asset_section.get(
            "total_income_wan", round(total_income / 10000, 2)
        )
        total_expense = asset_section.get("total_expense", 0)
        total_expense_wan = asset_section.get(
            "total_expense_wan", round(total_expense / 10000, 2)
        )

        # 从工资收入获取真实工资数据
        salary_info = asset_section.get("salary_income", {})
        salary_total = salary_info.get("total", 0)
        salary_total_wan = salary_info.get("total_wan", round(salary_total / 10000, 2))

        # 【修复】从profile获取真正的真实收入（剔除后的收入）
        profile = self.profiles.get(name, {})
        summary = profile.get("summary", {})
        real_income_raw = summary.get("real_income", 0)
        real_income_wan = round(real_income_raw / 10000, 2) if real_income_raw else 0

        # 计算工资占真实收入的比例
        salary_ratio = (
            (salary_total_wan / real_income_wan * 100) if real_income_wan > 0 else 0
        )

        # 风险等级判定（基于五维评分）
        five_dim = data_section.get("five_dimension_score", {})
        risk_level = five_dim.get("risk_level", "low")

        overview = {
            "name": name,
            "total_inflow": total_income_wan,
            "total_outflow": total_expense_wan,
            "real_income": real_income_wan,
            "salary": salary_total_wan,
            "salary_ratio": round(salary_ratio, 1),
            "risk_level": risk_level,
        }

        # ===== 二、关键发现 =====
        key_findings = self._extract_key_findings_from_section(name, existing_section)

        # ===== 三、收入透视 =====
        income_breakdown = self._build_income_breakdown_from_section(
            name, existing_section
        )

        # ===== 四、支出去向 =====
        outflow_analysis = self._build_outflow_analysis_from_section(
            name, existing_section
        )

        # ===== 五、时序分析 =====
        temporal_analysis = self._build_temporal_analysis_from_section(
            name, existing_section
        )

        # ===== 六、关联分析 =====
        relationship_analysis = self._build_relationship_analysis_from_section(
            name, existing_section
        )

        return {
            "overview": overview,
            "key_findings": key_findings,
            "income_breakdown": income_breakdown,
            "outflow_analysis": outflow_analysis,
            "temporal_analysis": temporal_analysis,
            "relationship_analysis": relationship_analysis,
        }

    def _extract_key_findings_from_section(
        self, name: str, section: Dict
    ) -> List[Dict]:
        """从 section 提取关键发现"""
        findings = []
        data_section = section.get("data_analysis_section", {})
        asset_section = section.get("asset_income_section", {})

        # 1. 收支不匹配风险
        income_match = data_section.get("income_match_analysis", {})
        if income_match.get("has_income_expense_mismatch"):
            findings.append(
                {
                    "type": "risk",
                    "description": f"收支明显不匹配，支出超出收入{income_match.get('expense_exceed_income_wan', 0):.2f}万元",
                    "impact": f"需核实差额部分{income_match.get('expense_exceed_income_wan', 0):.2f}万元资金来源",
                }
            )

        # 2. 大额现金风险
        cash_analysis = data_section.get("large_cash_analysis", {})
        cash_total_wan = cash_analysis.get("total_wan", 0)
        if cash_total_wan > 50:  # 50万元阈值
            findings.append(
                {
                    "type": "risk",
                    "description": f"存在大额现金交易{cash_total_wan:.2f}万元",
                    "impact": f"占总收入{(cash_total_wan / asset_section.get('total_income_wan', 1) * 100):.1f}%，需核查现金来源",
                }
            )

        # 3. 房产购置支付异常
        prop_analysis = data_section.get("property_analysis", {})
        if prop_analysis.get("has_payment_record") is False and prop_analysis.get(
            "has_data"
        ):
            total_value = prop_analysis.get("total_value", 0)
            if total_value > 0:
                findings.append(
                    {
                        "type": "warning",
                        "description": f"房产总价{total_value:.2f}万元，未在银行流水中查见购房款支付记录",
                        "impact": "需进一步确认其配偶或其他家庭成员的银行流水支付情况",
                    }
                )

        # 4. 工资占比异常
        # 【修复】使用真实收入作为分母，而非原始流水
        salary_total = asset_section.get("salary_income", {}).get("total", 0)
        # 从profile获取真实收入
        profile = self.profiles.get(name, {})
        real_income = profile.get("summary", {}).get("real_income", 0)
        salary_ratio = (salary_total / real_income * 100) if real_income > 0 else 0

        if salary_ratio < 50 and real_income > 1000000:
            findings.append(
                {
                    "type": "risk",
                    "description": f"工资性收入占比仅{salary_ratio:.1f}%，存在大量非工资收入",
                    "impact": f"需核实{(100 - salary_ratio):.1f}%非工资收入来源",
                }
            )

        # 5. 借贷风险
        lending = data_section.get("lending_analysis", {})
        if lending and lending.get("has_multi_platform"):
            findings.append(
                {
                    "type": "risk",
                    "description": f"存在多头借贷行为，涉及{lending.get('total_platforms', 0)}个平台",
                    "impact": f"累计借款{lending.get('total_borrowing', 0) / 10000:.2f}万元，需关注偿债压力",
                }
            )

        # 6. 五维评分风险
        five_dim = data_section.get("five_dimension_score", {})
        if five_dim and five_dim.get("risk_level") == "high":
            total_score = five_dim.get("total_score", 0)
            findings.append(
                {
                    "type": "risk",
                    "description": f"五维度综合评分{total_score}分，风险等级高",
                    "impact": "建议深入调查其资金来源和去向",
                }
            )

        return findings

    def _build_income_breakdown_from_section(self, name: str, section: Dict) -> Dict:
        """从 section 构建收入透视"""
        asset_section = section.get("asset_income_section", {})
        data_section = section.get("data_analysis_section", {})
        total_income = asset_section.get("total_income", 0)
        total_income_wan = asset_section.get(
            "total_income_wan", round(total_income / 10000, 2)
        )
        # 【修复】优先使用 income_match 中已计算好的真实收入，如果不存在则从 profile 获取
        income_match = data_section.get("income_match_analysis", {})
        real_income_wan = income_match.get("real_income_wan", 0)

        # 如果 income_match 中没有，从 profile summary 获取
        if real_income_wan == 0:
            profile = self.profiles.get(name, {})
            real_income_raw = profile.get("summary", {}).get("real_income", 0)
            real_income_wan = (
                round(real_income_raw / 10000, 2) if real_income_raw else 0
            )

        # 【修复】从profile获取真正的扣除项（只包含确定非收入的项目）
        profile = self.profiles.get(name, {})
        offset_detail = profile.get("summary", {}).get("offset_detail", {})

        # 【修复】只显示真正的非收入项目（本金返还、内部转账）
        deductions = []
        total_deduction = 0

        # 1. 自我转账（账户间划转）- 确定不是收入
        self_transfer = offset_detail.get("self_transfer", 0)
        if self_transfer > 0:
            deductions.append(
                {
                    "name": "自我转账",
                    "amount": round(self_transfer / 10000, 2),
                    "reason": "账户间资金划转，非真实收入",
                }
            )
            total_deduction += self_transfer

        # 2. 理财赎回本金 - 确定不是收入
        wealth_principal = offset_detail.get("wealth_principal", 0)
        if wealth_principal > 0:
            deductions.append(
                {
                    "name": "理财赎回本金",
                    "amount": round(wealth_principal / 10000, 2),
                    "reason": "投资理财本金返还，非新增收入",
                }
            )
            total_deduction += wealth_principal

        # 3. 定存到期本金 - 确定不是收入
        deposit_redemption = offset_detail.get("deposit_redemption", 0)
        if deposit_redemption > 0:
            deductions.append(
                {
                    "name": "定存到期本金",
                    "amount": round(deposit_redemption / 10000, 2),
                    "reason": "定期存款到期，非新增收入",
                }
            )
            total_deduction += deposit_redemption

        # 4. 其他本金类返还
        refund = offset_detail.get("refund", 0)
        if refund > 0:
            deductions.append(
                {
                    "name": "退款/返还",
                    "amount": round(refund / 10000, 2),
                    "reason": "款项退回，非新增收入",
                }
            )
            total_deduction += refund

        # 5. 历史理财（如果有）
        wealth_historical = offset_detail.get("wealth_historical", 0)
        if wealth_historical > 0:
            deductions.append(
                {
                    "name": "历史理财赎回",
                    "amount": round(wealth_historical / 10000, 2),
                    "reason": "历史理财本金返还",
                }
            )
            total_deduction += wealth_historical

        # 【修复】计算剩余的真实收入
        total_deduction_wan = round(total_deduction / 10000, 2)
        if total_deduction == 0:
            status = "verified"
        elif real_income_wan / total_income_wan > 0.5:
            status = "partial"
        else:
            status = "pending"

        return {
            "raw_inflow": total_income_wan,
            "deductions": deductions,
            "real_income": real_income_wan,  # 【修复】使用已计算的真实收入
            "status": status,
        }

    def _build_outflow_analysis_from_section(self, name: str, section: Dict) -> Dict:
        """从 section 构建支出去向分析"""
        data_section = section.get("data_analysis_section", {})
        counterparty = data_section.get("counterparty_analysis", {})
        outflow = counterparty.get("outflow", {})

